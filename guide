import { LETTERS } from \"../utils/medha\";

const PER_Q_SECONDS = 30;
const CIRC = 2 * Math.PI * 24;

export default function Exam({ questions, mood, onFinish }) {
  const [qi, setQi] = useState(0);
  const [selected, setSelected] = useState(null);
  const [confidence, setConfidence] = useState(null);
  const [secLeft, setSecLeft] = useState(PER_Q_SECONDS);

  const startRef = useRef(Date.now());
  const clicksRef = useRef([]); // letters clicked this question
  const itemsRef = useRef([]);
  const tickRef = useRef(null);

  const q = questions[qi];

  const commitQuestion = useCallback((finalIndex, conf) => {
    const timeTaken = (Date.now() - startRef.current) / 1000;
    itemsRef.current.push({
      questionId: q.id,
      finalAnswerIndex: finalIndex,
      clickSequence: [...clicksRef.current],
      timeTaken: Math.max(0.5, timeTaken),
      confidence: conf,
    });
  }, [q]);

  const goNext = useCallback((finalIndex, conf) => {
    clearInterval(tickRef.current);
    commitQuestion(finalIndex, conf);
    if (qi < questions.length - 1) {
      setQi((p) => p + 1);
    } else {
      onFinish(itemsRef.current, mood);
    }
  }, [qi, questions.length, commitQuestion, onFinish, mood]);

  // reset per-question state + timer
  useEffect(() => {
    setSelected(null);
    setConfidence(null);
    setSecLeft(PER_Q_SECONDS);
    startRef.current = Date.now();
    clicksRef.current = [];
    clearInterval(tickRef.current);
    tickRef.current = setInterval(() => {
      setSecLeft((s) => {
        if (s <= 1) {
          clearInterval(tickRef.current);
          // auto-advance using whatever is selected (may be null)
          setSelected((selNow) => {
            setConfidence((confNow) => {
              goNext(selNow, confNow);
              return confNow;
            });
            return selNow;
          });
          return 0;
        }
        return s - 1;
      });
    }, 1000);
    return () => clearInterval(tickRef.current);
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [qi]);

  const pickOption = (i) => {
    setSelected(i);
    clicksRef.current.push(LETTERS[i]);
  };

  const progress = ((qi + 1) / questions.length) * 100;
  const offset = CIRC * (1 - secLeft / PER_Q_SECONDS);
  const urgent = secLeft <= 8;
  const isLast = qi === questions.length - 1;

  return (
    <div className=\"view\" data-testid=\"exam-view\">
      <div className=\"wrap exam-wrap\">
